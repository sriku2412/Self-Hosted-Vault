ENVIRONMENT=production
APP_NAME=Selfhosted Vault

# Generate with:
#   openssl rand -base64 48
APP_SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-different-long-random-secret

# Set to your public hostnames. Include localhost only for local testing.
TRUSTED_HOSTS=vault.example.com,localhost,127.0.0.1

# Keep true behind HTTPS. Set false only for direct local HTTP testing.
SECURE_COOKIES=true
FORCE_HTTPS=false

# The first user can always register and becomes admin. After that, admins can close registration.
REGISTRATION_ENABLED=true

# Browser-side PBKDF2 iterations for the master password.
KDF_ITERATIONS=600000
MAX_LOGIN_ATTEMPTS_PER_MINUTE=8

